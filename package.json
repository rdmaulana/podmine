{
  "name": "podmine",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun --filter @podmine/api dev",
    "dev:worker": "bun --filter @podmine/worker dev",
    "dev:web": "bun --filter @podmine/web dev",
    "build": "bun run build:all"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
