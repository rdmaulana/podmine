# API Gateway Server Port
PORT=3000

# Database Configuration (MySQL)
DATABASE_URL="mysql://root:root@localhost:3306/podmine"

# Redis Configuration (Used by BullMQ Queue)
REDIS_HOST="localhost"
REDIS_PORT=6380
REDIS_PASSWORD=""

# JWT Authentication
JWT_SECRET="podmine-super-secret-key-change-me"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Driver Selectors (Options listed in packages/config/src/index.ts)
AI_SCRIPT_DRIVER="gemini"    # Options: gemini | openai | ollama
AI_TTS_DRIVER="elevenlabs"    # Options: elevenlabs | piper | kokoro
STORAGE_DRIVER="r2"           # Options: r2 | local

# Google Gemini API Kredensial
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ElevenLabs TTS API Kredensial
ELEVENLABS_API_KEY="YOUR_ELEVENLABS_API_KEY"
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM" # Default Voice (Rachel)

# Piper Local TTS HTTP API Configuration (Only used if AI_TTS_DRIVER="piper")
PIPER_HOST_A_URL="http://localhost:5001"
PIPER_HOST_B_URL="http://localhost:5002"

# Cloudflare R2 / S3 Compatible Storage Configuration
R2_ACCESS_KEY_ID="YOUR_R2_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="YOUR_R2_SECRET_ACCESS_KEY"
R2_BUCKET_NAME="YOUR_R2_BUCKET_NAME"
R2_ENDPOINT="https://<your-account-id>.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://cdn.techbro.biz.id" # Public CDN custom domain (optional)
